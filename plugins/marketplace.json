    {
      "name": "fixed-chunker",
      "title": "Fixed Size Chunker",
      "description": "Decoupe les documents en chunks de taille fixe avec overlap. Simple et efficace.",
      "category": "chunker",
      "version": "1.0.0",
      "author": "Retrieva",
      "icon": "scissors",
      "tags": ["chunking", "simple", "default"],
      "config_schema": {
        "chunk_size": { "type": "number", "default": 512, "label": "Taille du chunk (tokens)", "min": 100, "max": 4000 },
        "chunk_overlap": { "type": "number", "default": 50, "label": "Overlap (tokens)", "min": 0, "max": 500 }
      }
    },
    {
      "name": "semantic-chunker",
      "title": "Semantic Chunker",
      "description": "Decoupe intelligente basee sur le sens. Meilleure qualite pour le RAG.",
      "category": "chunker",
      "version": "1.0.0",
      "author": "Retrieva",
      "icon": "scissors",
      "tags": ["chunking", "smart", "quality"],
      "config_schema": {
        "threshold": { "type": "number", "default": 0.5, "label": "Seuil de similarite", "min": 0.1, "max": 0.9 },
        "min_chunk_size": { "type": "number", "default": 100, "label": "Taille min (tokens)", "min": 50, "max": 500 },
        "max_chunk_size": { "type": "number", "default": 1000, "label": "Taille max (tokens)", "min": 200, "max": 4000 }
      }
    },
    {
      "name": "document-chunker",
