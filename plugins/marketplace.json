        "url": { "type": "string", "default": "http://localhost:6333", "label": "Qdrant URL" },
        "api_key": { "type": "string", "default": "", "label": "API Key (optionnel)", "secret": true },
        "collection_prefix": { "type": "string", "default": "retrieva_", "label": "Prefixe des collections" }
      }
    },
    {
