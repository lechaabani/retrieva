        "content_path": { "type": "string", "default": "$.data[*].content", "label": "JSONPath vers le contenu" }
      }
    },
    {
      "name": "cohere-reranker",
      "title": "Cohere Reranker",
      "description": "Reranking des resultats avec Cohere rerank-v3. Ameliore la precision de 15-30%.",
      "category": "reranker",
      "version": "1.0.0",
      "author": "Retrieva",
      "icon": "arrow-up-down",
      "tags": ["reranking", "quality", "cloud"],
      "config_schema": {
        "api_key": { "type": "string", "label": "Cohere API Key", "secret": true },
        "model": { "type": "select", "default": "rerank-multilingual-v3.0", "label": "Modele", "options": ["rerank-multilingual-v3.0", "rerank-english-v3.0"] },
