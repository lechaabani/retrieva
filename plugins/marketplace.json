      "name": "pii-guardrail",
      "title": "PII Detection",
      "description": "Detecte et masque les donnees personnelles (email, telephone, SSN) dans les reponses.",
      "category": "guardrail",
      "version": "1.0.0",
      "author": "Retrieva",
      "icon": "shield",
      "tags": ["security", "privacy", "compliance"],
      "config_schema": {
        "mask_emails": { "type": "boolean", "default": true, "label": "Masquer les emails" },
        "mask_phones": { "type": "boolean", "default": true, "label": "Masquer les telephones" },
        "mask_pattern": { "type": "string", "default": "***", "label": "Caractere de masquage" }
      }
    },
    {
      "name": "toxicity-guardrail",
      "title": "Toxicity Filter",
      "description": "Filtre les contenus toxiques, offensants ou inappropries des reponses.",
      "category": "guardrail",
      "version": "1.0.0",
      "author": "Retrieva",
      "icon": "shield-alert",
      "tags": ["security", "moderation", "safety"],
      "config_schema": {
        "threshold": { "type": "number", "default": 0.7, "label": "Seuil de toxicite", "min": 0.1, "max": 1.0 },
        "block_response": { "type": "boolean", "default": true, "label": "Bloquer les reponses toxiques" }
      }
