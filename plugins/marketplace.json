      "category": "retriever",
      "version": "1.0.0",
      "author": "Retrieva",
      "icon": "database",
      "tags": ["vector-db", "hybrid-search", "open-source"],
      "config_schema": {
        "url": { "type": "string", "default": "http://localhost:8080", "label": "Weaviate URL" },
        "api_key": { "type": "string", "default": "", "label": "API Key", "secret": true }
      }
    },
    {
      "name": "openai-embedder",
      "title": "OpenAI Embeddings",
      "description": "text-embedding-3-small/large. Meilleur rapport qualite/prix pour l'embedding.",
      "category": "embedder",
      "version": "1.0.0",
      "author": "Retrieva",
      "icon": "brain",
      "tags": ["embedding", "cloud", "recommended"],
      "config_schema": {
        "api_key": { "type": "string", "label": "OpenAI API Key", "secret": true },
        "model": { "type": "select", "default": "text-embedding-3-small", "label": "Modele", "options": ["text-embedding-3-small", "text-embedding-3-large", "text-embedding-ada-002"] }
      }
    },
    {
      "name": "cohere-embedder",
      "title": "Cohere Embeddings",
      "description": "embed-multilingual-v3. Excellent pour le contenu multilingue.",
      "category": "embedder",
      "version": "1.0.0",
      "author": "Retrieva",
      "icon": "brain",
      "tags": ["embedding", "multilingual", "cloud"],
      "config_schema": {
        "api_key": { "type": "string", "label": "Cohere API Key", "secret": true },
        "model": { "type": "select", "default": "embed-multilingual-v3.0", "label": "Modele", "options": ["embed-multilingual-v3.0", "embed-english-v3.0", "embed-multilingual-light-v3.0"] }
      }
    },
    {
      "name": "huggingface-embedder",
      "title": "HuggingFace Local",
      "description": "Modeles d'embedding locaux via sentence-transformers. Gratuit, sans API key.",
      "category": "embedder",
      "version": "1.0.0",
      "author": "Retrieva",
      "icon": "cpu",
      "tags": ["embedding", "local", "free", "open-source"],
      "config_schema": {
        "model_name": { "type": "string", "default": "all-MiniLM-L6-v2", "label": "Nom du modele" },
        "device": { "type": "select", "default": "cpu", "label": "Device", "options": ["cpu", "cuda"] }
      }
    },
    {
      "name": "ollama-embedder",
      "title": "Ollama Embeddings",
      "description": "Embedding via Ollama. Fonctionne avec nomic-embed-text, mxbai-embed-large.",
      "category": "embedder",
      "version": "1.0.0",
      "author": "Retrieva",
      "icon": "server",
      "tags": ["embedding", "local", "free"],
      "config_schema": {
        "base_url": { "type": "string", "default": "http://localhost:11434", "label": "Ollama URL" },
        "model": { "type": "string", "default": "nomic-embed-text", "label": "Modele" }
      }
    },
    {
      "name": "openai-generator",
      "title": "OpenAI GPT",
      "description": "GPT-4o, GPT-4o-mini. Le generateur le plus populaire pour le RAG.",
      "category": "generator",
      "version": "1.0.0",
      "author": "Retrieva",
      "icon": "sparkles",
      "tags": ["generation", "cloud", "recommended"],
      "config_schema": {
        "api_key": { "type": "string", "label": "OpenAI API Key", "secret": true },
        "model": { "type": "select", "default": "gpt-4o-mini", "label": "Modele", "options": ["gpt-4o", "gpt-4o-mini", "gpt-4-turbo", "gpt-3.5-turbo"] },
        "temperature": { "type": "number", "default": 0.7, "label": "Temperature", "min": 0, "max": 2 },
        "max_tokens": { "type": "number", "default": 1024, "label": "Max tokens", "min": 100, "max": 4096 }
      }
    },
    {
      "name": "anthropic-generator",
      "title": "Anthropic Claude",
      "description": "Claude Sonnet 4.5, Opus 4.6. Excellent pour les reponses longues et nuancees.",
      "category": "generator",
      "version": "1.0.0",
      "author": "Retrieva",
      "icon": "sparkles",
      "tags": ["generation", "cloud", "high-quality"],
      "config_schema": {
        "api_key": { "type": "string", "label": "Anthropic API Key", "secret": true },
        "model": { "type": "select", "default": "claude-sonnet-4-5-20250929", "label": "Modele", "options": ["claude-opus-4-6", "claude-sonnet-4-5-20250929", "claude-haiku-4-5-20251001"] },
        "temperature": { "type": "number", "default": 0.7, "label": "Temperature", "min": 0, "max": 1 },
        "max_tokens": { "type": "number", "default": 1024, "label": "Max tokens", "min": 100, "max": 4096 }
      }
    },
    {
      "name": "ollama-generator",
      "title": "Ollama (Local LLM)",
      "description": "Llama 3, Mistral, Phi-3 en local. Gratuit, donnees restent sur votre serveur.",
      "category": "generator",
      "version": "1.0.0",
      "author": "Retrieva",
      "icon": "server",
      "tags": ["generation", "local", "free", "privacy"],
      "config_schema": {
        "base_url": { "type": "string", "default": "http://localhost:11434", "label": "Ollama URL" },
        "model": { "type": "string", "default": "llama3.1", "label": "Modele" },
        "temperature": { "type": "number", "default": 0.7, "label": "Temperature", "min": 0, "max": 2 }
      }
    },
    {
      "name": "mistral-generator",
      "title": "Mistral AI",
      "description": "Mistral Large, Mistral Small. Modeles europeens performants.",
      "category": "generator",
      "version": "1.0.0",
      "author": "Retrieva",
      "icon": "sparkles",
      "tags": ["generation", "cloud", "european"],
      "config_schema": {
        "api_key": { "type": "string", "label": "Mistral API Key", "secret": true },
        "model": { "type": "select", "default": "mistral-small-latest", "label": "Modele", "options": ["mistral-large-latest", "mistral-small-latest", "mistral-medium-latest"] }
      }
