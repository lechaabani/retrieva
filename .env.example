# ============================================================================
# Retrieva - Le WordPress du RAG
# ============================================================================
# Ce fichier est OPTIONNEL pour le developpement.
# Copiez-le en .env : cp .env.example .env
# Les cles API sont configurees via le Setup Wizard (localhost:3000).
# ============================================================================

# -- Securite (recommande en production) ------------------------------------
# JWT_SECRET_KEY=generate-a-random-secret-here

# -- Ports (optionnel) ------------------------------------------------------
# API_PORT=8000

# -- Base de donnees (les defauts Docker fonctionnent sans modification) -----
# POSTGRES_USER=retrieva
# POSTGRES_PASSWORD=retrieva
# POSTGRES_DB=retrieva
